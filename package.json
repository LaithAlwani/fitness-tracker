{
  "name": "liftify",
  "version": "0.0.0",
  "private": true,
  "description": "Liftify — fast workout tracker web PWA (Next.js + Convex + Clerk).",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "web": "npm run dev --workspace @liftify/web",
    "convex:dev": "npm exec --workspace @liftify/convex -- convex dev",
    "convex:deploy": "npm exec --workspace @liftify/convex -- convex deploy"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
