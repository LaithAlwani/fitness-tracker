# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored.

# From Clerk dashboard → API Keys → Publishable key (pk_test_...).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# From Convex dashboard after running `pnpm convex:dev` (e.g. https://example-name-123.convex.cloud).
EXPO_PUBLIC_CONVEX_URL=https://replace-me.convex.cloud
