# Copy to .env.local and fill in real values. .env.local is git-ignored.

# Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Clerk sign-in / sign-up routes (App Router)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Convex dashboard after `npm run convex` (e.g. https://example-name-123.convex.cloud)
NEXT_PUBLIC_CONVEX_URL=https://replace-me.convex.cloud

# Public base URL of this app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Shop — Amazon Associates tag (e.g. yourtag-20). Appended to product links.
# Leave blank and products with no asin/url show "Coming soon". See lib/shop.ts.
NEXT_PUBLIC_AMAZON_TAG=
# Amazon store domain for affiliate links (only set if not .com, e.g. amazon.ca)
NEXT_PUBLIC_AMAZON_DOMAIN=

# ---------------------------------------------------------------------------
# The following are set on the CONVEX deployment (not here), via
#   npx convex env set NAME value
# Listed for reference:
#   CLERK_JWT_ISSUER_DOMAIN   # Clerk → JWT Templates → Convex issuer URL
#   STRIPE_SECRET_KEY         # sk_test_... / sk_live_...
#   STRIPE_WEBHOOK_SECRET     # whsec_... from the Stripe webhook endpoint
#   STRIPE_PRICE_ID           # price_... for the $6.99/mo recurring price
# ---------------------------------------------------------------------------

# Stripe publishable key (pk_test_... / pk_live_...) for in-app card updates
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Web Push VAPID public key (matches VAPID_PUBLIC_KEY on Convex)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
